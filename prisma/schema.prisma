generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Dominio (Organización / Tenant) ---

model Dominio {
  id            String   @id @default(uuid())
  clave         String   @unique
  nombre        String
  logoUrl       String?
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  solicitudes      Solicitud[]
  grupos           GrupoAprobacion[]      @relation("GrupoDominio")
  ubicaciones      Ubicacion[]            @relation("UbicacionDominio")
  incidentes       Incidente[]            @relation("IncidenteDominio")
  tiposAprobacion  TipoAprobacion[]       @relation("TipoAprobacionDominio")
  reglas           ReglaFormularioCampo[] @relation("ReglaDominio")
  camposFormulario CampoFormulario[]
  usuarios         UsuarioDominio[]
}

model UsuarioDominio {
  id        String   @id @default(uuid())
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  dominioId String
  dominio   Dominio  @relation(fields: [dominioId], references: [id], onDelete: Cascade)
  rol       String   @default("usuario") // rol dentro de este dominio
  creadoEn  DateTime @default(now())

  @@unique([usuarioId, dominioId])
}

// --- Campos Dinámicos por Dominio ---

model CampoFormulario {
  id            String   @id @default(uuid())
  dominioId     String
  dominio       Dominio  @relation(fields: [dominioId], references: [id], onDelete: Cascade)
  modulo        String   @default("todos") // "acreedores" | "proveedores" | "materiales" | "todos"
  formulario    String   @default("alta") // "alta" | "actualizacion"
  seccion       String   @default("custom") // "datos_generales", "direccion", "custom"
  clave         String // slug único por dominio, ej: "nro_proveedor"
  etiqueta      String // "Número de Proveedor"
  tipo          String   @default("text") // text, number, select, date, textarea, checkbox, file, email, phone
  requerido     Boolean  @default(false)
  orden         Int      @default(0)
  opciones      Json? // para selects: [{value, label}]
  validacion    Json? // {regex, min, max, minLength, etc.}
  placeholder   String?
  tooltip       String?
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([dominioId, clave])
  @@index([dominioId, formulario])
}

model Solicitud {
  id            String   @id @default(uuid())
  folio         String   @unique
  modulo        String   @default("acreedores") // "acreedores" | "proveedores"
  tipo          String   @default("alta") // alta, actualizacion
  estado        String   @default("borrador") // borrador, enviada, en_revision, aprobada, rechazada, registrado, error_sap
  pasoActual    Int      @default(1)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  // Dominio (tenant)
  dominioId String?
  dominio   Dominio? @relation(fields: [dominioId], references: [id])

  // Campos dinámicos (JSON)
  camposExtra Json?

  // Campos específicos de actualización
  movimientoRealizar String? // tipo de movimiento (banco, domicilio, razon_social, documentos)
  acreedorReferencia String? // nombre/razón social del acreedor a actualizar
  acreedorNumero     String? // número/ID SAP del acreedor

  // Paso 1: Información del solicitante
  solicitanteNombre String?
  solicitanteArea   String?
  sucursalId        String?
  sucursal          CatSucursal? @relation(fields: [sucursalId], references: [id])

  // BP Partner (ID externo)
  bpPartner String?

  // Paso 2: Datos del acreedor
  rfc                        String?
  tipoAcreedorId             String?
  tipoAcreedor               CatTipoAcreedor? @relation(fields: [tipoAcreedorId], references: [id])
  grupoCuentasId             String?
  grupoCuentas               CatGrupoCuentas? @relation(fields: [grupoCuentasId], references: [id])
  cuentaAsociada             String?
  acreedoresNoEspecializados String?
  casosEspeciales            String?
  serviciosEspeciales        String?
  areasSolicitantes          String?
  razonSocial                String?
  nombreComercial            String?
  apellidoPaterno            String?
  nombrePila                 String?
  apellidoMaterno            String?
  tipoPersona                String? // moral, fisica
  type                       String? // 1=Moral, 2=Fisica (campo oculto de control)
  clasificacionAcreedor      String?

  // Pago
  condicionPagoId String?
  condicionPago   CatCondicionPago? @relation(fields: [condicionPagoId], references: [id])
  monedaPago      String? // MXN, USD, EUR
  viaPago         String?
  cuentaClabe     String?
  nombreBanco     String?
  monedaPedido    String?

  // Datos generales (sección 2.4)
  localizacion String? // nacional, extranjero

  // Dirección
  calle                   String?
  numeroExterior          String?
  numeroInterior          String?
  codigoPostal            String?
  colonia                 String? // CITY2
  distritoColoniaOpcional String? // distrito_colonia_opcional
  estado_dir              String? // REGION
  municipio               String? // CITY1
  regionExt               String? // region_ext (extranjero)
  paisExt                 String? // pais_ext (extranjero)

  // Datos generales
  conceptoBusqueda  String?
  bienServicio      String?
  empresaReconocida String?

  // Cobertura
  cdrCobertura String? // JSON array of selected sucursales

  // Contacto del acreedor (multi-row, max 4)
  contactos ContactoAcreedor[]

  // Retención (auto-poblados)
  esquemaResico      String?
  tipoRetencion      String?
  indicadorRetencion String?

  // Datos nuevos de actualización (JSON con campos específicos por movimiento)
  datosActualizacion String? // JSON: {n_calle, n_numero_exterior, ...} según movimiento

  // Justificación (requerido en actualización)
  justificacion String?

  // Bloqueo/Desbloqueo
  bloqueoContabilizacionActual Boolean?
  bloqueoContabilizacionNuevo  Boolean?

  // ═══════════════════════════════════════════════════════════
  // Campos exclusivos de PROVEEDORES (modulo = "proveedores")
  // ═══════════════════════════════════════════════════════════

  // Asignación negociador / comprador
  compradorJr        String?
  negociadorAsignado String?
  dga                String?

  // Dirección fiscal extra (proveedor)
  numDepartamento String?
  piso            String?
  pais            String?

  // Contacto fiscal
  contactoFiscalNombre    String?
  contactoFiscalExtension String?
  contactoFiscalTelefono  String?
  contactoFiscalCorreo    String?

  // Convenio comercial
  descuentosFee          String?
  descuentosRrrp         String?
  porcentajeNoDevolucion String?
  comentarioDescuento    String?
  modalidad              String?
  tipoEntrega            String?
  escalaEntrega          String?
  plazoPago              String?
  cuentaBancaria         String?

  // Devolución
  mercanciaVencida     String?
  mercanciaDeteriorada String?
  mercanciaBuenEstado  String?
  penalizacion         String?

  // Contactos de organización — KAM
  nombreKam             String?
  telefonoKam           String?
  correoKam             String?
  // Ejecutivo de cuenta
  nombreEjecutivo       String?
  telefonoEjecutivo     String?
  correoEjecutivo       String?
  // Gerente comercial
  nombreGerente         String?
  telefonoGerente       String?
  correoGerente         String?
  // Director comercial
  nombreDirector        String?
  telefonoDirector      String?
  correoDirector        String?
  // Cuentas por pagar
  nombreCuentasPagar    String?
  telefonoCuentasPagar  String?
  correoCuentasPagar    String?
  // Representante legal
  nombreRepresentante   String?
  telefonoRepresentante String?
  correoRepresentante   String?
  // Responsable de calidad
  nombreRCalidad        String?
  telefonoRCalidad      String?
  correoRCalidad        String?
  // Responsable sanitario
  nombreRSanitario      String?
  telefonoRSanitario    String?
  correoRSanitario      String?

  // Términos y condiciones (proveedor)
  aceptaTerminos String?

  // ═══════════════════════════════════════════════════════════

  // Cláusula
  aceptaClausula Boolean @default(false)

  // Documentos
  documentos Documento[]

  // Grupo de asignación (opcional, referencia a GrupoAprobacion)
  grupoAsignadoId String?
  grupoAsignado   GrupoAprobacion? @relation("SolicitudGrupo", fields: [grupoAsignadoId], references: [id])

  // Aprobaciones
  aprobaciones Aprobacion[]

  // Tareas del flujo (timeline reactivo desde n8n)
  tareas TareaSolicitud[]

  // Tareas de flujo (asignación de aprobador)
  tareasFlujo TareaFlujo[] @relation("TareasFlujoSolicitud")
}

// --- Tareas del Flujo (asignación de aprobador por usuario) ---

model TareaFlujo {
  id                String           @id @default(uuid())
  solicitudId       String
  solicitud         Solicitud        @relation("TareasFlujoSolicitud", fields: [solicitudId], references: [id], onDelete: Cascade)
  titulo            String // Ej: "Asignar aprobador gerencial"
  descripcion       String? // Instrucciones adicionales
  estado            String           @default("abierta") // abierta, cerrada
  grupoAsignadoId   String? // Grupo de aprobación predefinido por n8n
  grupoAsignado     GrupoAprobacion? @relation("TareaFlujoGrupo", fields: [grupoAsignadoId], references: [id])
  miembroAsignadoId String? // Miembro del grupo al que se asigna la tarea
  miembroAsignado   Usuario?         @relation("TareaFlujoMiembro", fields: [miembroAsignadoId], references: [id])
  aprobadorId       String? // Aprobador seleccionado por el usuario al cerrar la tarea
  aprobador         Usuario?         @relation("TareaFlujoAprobador", fields: [aprobadorId], references: [id])
  resumeUrl         String? // URL de callback para n8n (Wait on Webhook)
  fechaCierre       DateTime?
  creadoEn          DateTime         @default(now())
  actualizadoEn     DateTime         @updatedAt

  @@unique([solicitudId, grupoAsignadoId])
  @@index([solicitudId])
  @@index([estado])
}

// --- Tareas del Flujo Timeline (Timeline controlado por n8n) ---

model TareaSolicitud {
  id            String    @id @default(uuid())
  solicitudId   String
  solicitud     Solicitud @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  titulo        String // Ej: "Solicitud Enviada", "Aprobación Gerencial"
  estado        String    @default("pendiente") // completado, activo, pendiente
  detalle       String? // Ej: "Enviada el 21 may", "Pendiente"
  subtexto      String? // Ej: "Folio asignado: SOL-2026-0029"
  orden         Int       @default(0)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  @@index([solicitudId])
}

model ContactoAcreedor {
  id          String    @id @default(uuid())
  solicitudId String
  solicitud   Solicitud @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  orden       Int       @default(0)
  nombre      String
  correo      String
  puesto      String
  telefono    String
  extension   String?
  cdr         String
  creadoEn    DateTime  @default(now())
}

model Documento {
  id              String    @id @default(uuid())
  solicitudId     String
  solicitud       Solicitud @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  tipoDocumento   String // clave del tipo de documento
  nombreArchivo   String
  rutaArchivo     String? // legacy file path (optional)
  contenidoBase64 String? // base64 encoded content
  tamanio         Int // bytes
  mimeType        String
  creadoEn        DateTime  @default(now())
}

model DocumentoTemporal {
  id              String   @id @default(uuid())
  sessionKey      String // unique key per form session
  tipoDocumento   String
  nombreArchivo   String
  contenidoBase64 String // base64 encoded content
  tamanio         Int
  mimeType        String
  creadoEn        DateTime @default(now())

  @@index([sessionKey])
}

// --- Aprobaciones ---

model Aprobacion {
  id               String           @id @default(uuid())
  solicitudId      String
  solicitud        Solicitud        @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  descripcionCorta String?
  estado           String           @default("solicitado") // solicitado, no_requerido, aprobado, rechazado
  grupoAsignadoId  String? // Opcional: null = aprobación individual
  grupoAsignado    GrupoAprobacion? @relation(fields: [grupoAsignadoId], references: [id])
  aprobadorId      String
  aprobador        Usuario          @relation(fields: [aprobadorId], references: [id])
  resumeUrl        String? // URL de callback para n8n (Wait on Webhook)
  comentario       String? // Comentario al aprobar/rechazar
  fechaResolucion  DateTime?
  creadoEn         DateTime         @default(now())
  actualizadoEn    DateTime         @updatedAt
}

model GrupoAprobacion {
  id              String           @id @default(uuid())
  nombre          String           @unique
  descripcion     String?
  roles           String           @default("[]") // JSON array: ["aprobador","admin","owner","solicitante"]
  dominioId       String?
  dominio         Dominio?         @relation("GrupoDominio", fields: [dominioId], references: [id])
  activo          Boolean          @default(true)
  creadoEn        DateTime         @default(now())
  actualizadoEn   DateTime         @updatedAt
  miembros        MiembroGrupo[]
  aprobaciones    Aprobacion[]
  solicitudes     Solicitud[]      @relation("SolicitudGrupo")
  tiposAprobacion TipoAprobacion[] @relation("TipoAprobacionGrupo")
  tareasFlujo     TareaFlujo[]     @relation("TareaFlujoGrupo")
}

model MiembroGrupo {
  id        String          @id @default(uuid())
  grupoId   String
  grupo     GrupoAprobacion @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  usuarioId String
  usuario   Usuario         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  creadoEn  DateTime        @default(now())

  @@unique([grupoId, usuarioId])
}

// --- Usuarios (SSO) ---

model Usuario {
  id            String    @id @default(uuid())
  ssoId         String    @unique // ID del usuario en el sistema SSO externo
  email         String    @unique
  username      String?
  nombre        String?
  roles         String    @default("[]") // JSON array de roles del SSO, ej: ["Administrador","Developer"]
  rolInterno    String    @default("usuario") // admin, developer, usuario
  activo        Boolean   @default(true)
  ultimoAcceso  DateTime?
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  // Dominio (multi-tenant)
  dominioActualId String? // dominio activo en sesión
  esSuperAdmin    Boolean @default(false)

  // Campos adicionales
  areaHumana     String?
  linea          String?
  employeeNumber String?    @unique
  contrasena     String?
  managerId      String?
  manager        Usuario?   @relation("UsuarioManager", fields: [managerId], references: [id])
  subordinados   Usuario[]  @relation("UsuarioManager")
  ubicacionId    String?
  ubicacion      Ubicacion? @relation("UsuarioUbicacion", fields: [ubicacionId], references: [id])

  aprobaciones             Aprobacion[]
  membresiaGrupos          MiembroGrupo[]
  dominios                 UsuarioDominio[]
  tiposAprobacionAsignadas TipoAprobacion[] @relation("TipoAprobacionAprobador")
  ubicacionesGerenciadas   Ubicacion[]      @relation("UbicacionBranchManager")
  incidentesReportados     Incidente[]      @relation("IncidenteReportador")
  incidentesAsignados      Incidente[]      @relation("IncidenteAsignado")
  tareasFlujoMiembro       TareaFlujo[]     @relation("TareaFlujoMiembro")
  tareasFlujoAprobador     TareaFlujo[]     @relation("TareaFlujoAprobador")
  pushSubscriptions        PushSubscription[]
}

// --- Ubicaciones ---

model Ubicacion {
  id                    String    @id @default(uuid())
  nombre                String    @unique
  calle                 String?
  ciudad                String?
  estadoProvincia       String?
  codigoPostal          String?
  pais                  String?   @default("MX")
  esSucursal            Boolean   @default(false)
  telefono              String?
  latitud               Float?
  longitud              Float?
  branchOffice          String?
  branchOfficeManagerId String?
  branchOfficeManager   Usuario?  @relation("UbicacionBranchManager", fields: [branchOfficeManagerId], references: [id])
  supplyCenter          String?
  dominioId             String?
  dominio               Dominio?  @relation("UbicacionDominio", fields: [dominioId], references: [id])
  activo                Boolean   @default(true)
  creadoEn              DateTime  @default(now())
  actualizadoEn         DateTime  @updatedAt
  usuarios              Usuario[] @relation("UsuarioUbicacion")
}

// --- Catálogos ---

model CatSucursal {
  id          String      @id @default(uuid())
  codigo      String      @unique
  nombre      String
  activo      Boolean     @default(true)
  solicitudes Solicitud[]
}

model CatTipoAcreedor {
  id               String              @id @default(uuid())
  clave            String              @unique
  nombre           String
  activo           Boolean             @default(true)
  solicitudes      Solicitud[]
  cuentasAsociadas CatCuentaAsociada[]
}

model CatGrupoCuentas {
  id               String              @id @default(uuid())
  clave            String              @unique
  nombre           String
  activo           Boolean             @default(true)
  cuentasAsociadas CatCuentaAsociada[]
  solicitudes      Solicitud[]
}

model CatCuentaAsociada {
  id             String           @id @default(uuid())
  codigo         String
  nombre         String
  valorSap       String?
  grupoCuentasId String
  grupoCuentas   CatGrupoCuentas  @relation(fields: [grupoCuentasId], references: [id])
  tipoAcreedorId String?
  tipoAcreedor   CatTipoAcreedor? @relation(fields: [tipoAcreedorId], references: [id])
  activo         Boolean          @default(true)
  retenciones    CatRetencion[]
}

model CatRetencion {
  id                        String            @id @default(uuid())
  cuentaAsociadaId          String
  cuentaAsociada            CatCuentaAsociada @relation(fields: [cuentaAsociadaId], references: [id])
  esquemaResico             String?           @db.Text
  tipoRetencion             String?           @db.Text
  indicadorRetencionCuentas String?           @db.Text
  aplicaFisica              Boolean           @default(false)
  aplicaMoral               Boolean           @default(false)
  activo                    Boolean           @default(true)
}

model CatCondicionPago {
  id          String      @id @default(uuid())
  clave       String      @unique
  nombre      String
  activo      Boolean     @default(true)
  solicitudes Solicitud[]
}

model CatTipoDocumento {
  id          String  @id @default(uuid())
  clave       String  @unique
  nombre      String
  descripcion String?
  obligatorio Boolean @default(false)
  condicional Boolean @default(false)
  extensiones String // "pdf,jpeg,jpg,png"
  maxSizeMb   Int     @default(5)
  maxArchivos Int     @default(1)
  orden       Int     @default(0)
  icono       String? // material icon name
  condiciones String? // JSON: [{"campo":"tipo","operador":"==","valor":"actualizacion"},{"campo":"movimientoRealizar","operador":"==","valor":"banco"}]
  modulo      String  @default("acreedores") // "acreedores", "proveedores", "ambos"
  activo      Boolean @default(true)
}

model CatServiciosEspeciales {
  id     String  @id @default(uuid())
  clave  String  @unique
  nombre String
  activo Boolean @default(true)
}

model CatCasosEspeciales {
  id     String  @id @default(uuid())
  clave  String  @unique
  nombre String
  activo Boolean @default(true)
}

model CatAreaSolicitante {
  id     String  @id @default(uuid())
  clave  String  @unique
  nombre String
  activo Boolean @default(true)
}

model CatAcreedorNoEspecializado {
  id     String  @id @default(uuid())
  clave  String  @unique
  nombre String
  activo Boolean @default(true)
}

model CatMonedaPago {
  id     String  @id @default(uuid())
  clave  String  @unique
  nombre String
  activo Boolean @default(true)
}

model CatViaPago {
  id     String  @id @default(uuid())
  clave  String  @unique
  nombre String
  activo Boolean @default(true)
}

model CatMonedaPedido {
  id     String  @id @default(uuid())
  clave  String  @unique
  nombre String
  activo Boolean @default(true)
}

model CatClasificacionAcreedor {
  id     String  @id @default(uuid())
  clave  String  @unique
  nombre String
  activo Boolean @default(true)
}

model CatLocalizacion {
  id     String  @id @default(uuid())
  clave  String  @unique
  nombre String
  activo Boolean @default(true)
}

model CatBanco {
  id     String  @id @default(uuid())
  clave  String  @unique
  nombre String
  activo Boolean @default(true)
}

// --- Historial de Comunicación / Auditoría ---

model Actividad {
  id              String   @id @default(uuid())
  entidadTipo     String // "solicitud", "aprobacion"
  entidadId       String
  tipo            String // "comentario", "cambio_campo", "cambio_estado", "sistema"
  contenido       String? // texto del comentario o descripción
  campoModificado String? // nombre del campo para auditoría
  valorAnterior   String? // valor anterior (stringify)
  valorNuevo      String? // valor nuevo (stringify)
  visibleCliente  Boolean  @default(false)
  autorNombre     String?
  autorEmail      String?
  creadoEn        DateTime @default(now())

  @@index([entidadTipo, entidadId])
}

// --- Incidentes ---

model Incidente {
  id          String  @id @default(uuid())
  folio       String  @unique // INC-YYYY-XXXX
  categoria   String // error_sistema, acceso, rendimiento, datos, funcionalidad, otro
  prioridad   String  @default("media") // baja, media, alta, critica
  modulo      String? // solicitudes, aprobaciones, directorio, catalogos, usuarios, otro
  descripcion String
  estado      String  @default("nuevo") // nuevo, en_progreso, en_espera_info, resuelto, cerrado, cancelado

  reportadoPorId String
  reportadoPor   Usuario @relation("IncidenteReportador", fields: [reportadoPorId], references: [id])

  asignadoAId String?
  asignadoA   Usuario? @relation("IncidenteAsignado", fields: [asignadoAId], references: [id])

  dominioId String?
  dominio   Dominio? @relation("IncidenteDominio", fields: [dominioId], references: [id])

  comentarioResolucion String?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
}

// --- Tipos de Aprobación (módulo auxiliar para flujos n8n) ---

model TipoAprobacion {
  id                  String           @id @default(uuid())
  nombre              String
  tipo                String // "grupal" o "individual"
  grupoAsignadoId     String?
  grupoAsignado       GrupoAprobacion? @relation("TipoAprobacionGrupo", fields: [grupoAsignadoId], references: [id])
  aprobadorAsignadoId String?
  aprobadorAsignado   Usuario?         @relation("TipoAprobacionAprobador", fields: [aprobadorAsignadoId], references: [id])
  dominioId           String?
  dominio             Dominio?         @relation("TipoAprobacionDominio", fields: [dominioId], references: [id])
  orden               Int              @default(100)
  activo              Boolean          @default(true)
  creadoEn            DateTime         @default(now())
  actualizadoEn       DateTime         @updatedAt
}

// --- Reglas de Formulario (UI Policies — Visibilidad, Obligatoriedad, Read Only) ---

model ReglaFormularioCampo {
  id                String   @id @default(uuid())
  campo             String // nombre del campo del formulario (ej: "razonSocial", "cuentaClabe")
  condiciones       String // JSON array de reglas: [{ campo, operador, valor }]
  logica            String   @default("AND") // "AND" = todas deben cumplirse, "OR" = al menos una
  accionVisible     String   @default("no_cambiar") // "mostrar", "ocultar", "no_cambiar"
  accionObligatorio String   @default("no_cambiar") // "requerir", "no_requerir", "no_cambiar"
  accionReadOnly    String   @default("no_cambiar") // "solo_lectura", "editable", "no_cambiar"
  reverseIfFalse    Boolean  @default(false) // si true, aplica la acción inversa cuando NO se cumplen las condiciones
  formulario        String   @default("alta") // "alta", "actualizacion", "ambos"
  modulo            String   @default("acreedores") // "acreedores", "proveedores", "ambos"
  dominioId         String?
  dominio           Dominio? @relation("ReglaDominio", fields: [dominioId], references: [id])
  orden             Int      @default(0)
  activo            Boolean  @default(true)
  creadoEn          DateTime @default(now())
  actualizadoEn     DateTime @updatedAt

  @@index([formulario])
  @@index([campo])
  @@index([modulo])
  @@index([dominioId])
  @@map("ReglaVisibilidadCampo")
}

// --- Push Notifications (PWA) ---

model PushSubscription {
  id        String   @id @default(uuid())
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now())

  @@index([usuarioId])
}

// --- Logs del Sistema ---

model LogSistema {
  id          String   @id @default(uuid())
  tipo        String   // login, impersonacion, sap_respuesta, error, admin_accion
  accion      String   // descripción corta de la acción
  detalle     String?  @db.Text // descripción detallada o JSON con datos adicionales
  nivel       String   @default("info") // info, warn, error
  usuarioId   String?  // quién ejecutó la acción (puede ser null para eventos del sistema)
  usuarioEmail String?
  usuarioNombre String?
  ipAddress   String?
  userAgent   String?  @db.Text
  entidadTipo String?  // solicitud, aprobacion, usuario, etc.
  entidadId   String?  // ID de la entidad afectada
  metadata    String?  @db.Text // JSON libre para datos adicionales (ej: respuesta SAP, payload, etc.)
  creadoEn    DateTime @default(now())

  @@index([tipo])
  @@index([usuarioId])
  @@index([creadoEn])
  @@index([nivel])
  @@index([entidadTipo, entidadId])
}

model LogEmail {
  id            String   @id @default(uuid())
  asunto        String
  destinatarios String   @db.Text // JSON array de emails
  cc            String?  @db.Text // JSON array de emails en copia
  cco           String?  @db.Text // JSON array de emails en copia oculta
  bodyHtml      String?  @db.Text // contenido HTML del email
  bodyTexto     String?  @db.Text // contenido texto plano
  remitente     String?  // email del remitente
  estado        String   @default("enviado") // enviado, fallido, pendiente
  error         String?  @db.Text // mensaje de error si falló
  solicitudId   String?  // referencia opcional a solicitud relacionada
  usuarioId     String?  // quién disparó el envío
  metadata      String?  @db.Text // JSON: templateId, proveedor (smtp/sendgrid), messageId, etc.
  creadoEn      DateTime @default(now())

  @@index([estado])
  @@index([solicitudId])
  @@index([usuarioId])
  @@index([creadoEn])
}
